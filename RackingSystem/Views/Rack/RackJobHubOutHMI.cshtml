        function loadDBUpcoming() {
            const pendingList = document.getElementById('pendingList');
            const insufficientList = document.getElementById('insufficientList');

            // var count = document.querySelectorAll('.reel-card').length;
            // if (count.length === 0) {
            //     pendingList.innerHTML = '<div class="text-xs" style="color:#9ca3af;">No pending items</div>';
            //     return;
            // }
            // count = document.querySelectorAll('.reel-card-in').length;
            // if (count.length === 0) {
            //     insufficientList.innerHTML = '<div class="text-xs" style="color:#9ca3af;">No pending items</div>';
            //     return;
            // }

            $.ajax({
                url: "/api/PLCHubOut/GetUpcomingReels/" + qId + "/" + lastItemCount + "/" + lastItemId,
                type: "GET",
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                dataType: 'JSON',
                // data: JSON.stringify(jsonInput),
                contentType: 'application/json; charset=utf-8',
                beforeSend: function () {

                },
                success: function (result) {
                    // console.log(result);

                    if (result.totalRecords > 0) {
                        for (var i = 0; i < result.data.length; i++) {
                            let id = result.data[i].detail_Id;
                            let r = result.data[i].reel_Id;
                            let code = result.data[i].itemCode;
                            let qty = result.data[i].qty;

                            if (r == "") {
                                const item = document.createElement('div');
                                item.id = id;
                                item.className = 'reel-card text-xs px-2.5 py-1.5 rounded-lg flex items-center gap-2';
                                item.style.background = 'lemonchiffon';
                                item.style.borderLeft = `3px solid #ef4444`;
                                item.style.color = '#166534';
                                item.innerHTML = `<span style="color:#ef4444;font-weight:bold;">■</span> Reel ${r} • ${qty} x ${code} `;
                                insufficientList.appendChild(item);
                                totalInsufficient = totalInsufficient + 1;
                            }
                            else {
                                const item = document.createElement('div');
                                item.id = id;
                                item.className = 'reel-card-in text-xs px-2.5 py-1.5 rounded-lg flex items-center gap-2';
                                item.style.background = '#f0fdf4';
                                item.style.borderLeft = `3px solid ${TRAY_COLORS[i]}`;
                                item.style.color = '#166534';
                                item.innerHTML = `<span style="color:${TRAY_COLORS[i]};font-weight:bold;">■</span> ${qty} x ${code} `;
                                pendingList.appendChild(item);
                            }

                            lastItemId = id;
                            lastItemCount = lastItemCount + 1;
                            updateDash();
                        }
                    }

                    return true;
                },
                error: function (error) {
                    log('End Loader :: ' + error.val, 'alert');
                }
            });

        }

        function removeDBUpcoming(id) {
            // const pendingList = document.getElementById('pendingList');
            // const insufficientList = document.getElementById('insufficientList');

            const item = document.getElementById(id);

            // 3. Check if the element exists and then remove it
            if (item) {
                item.classList.add('fade-out');

                // 2. Wait for the animation to finish (500ms in this example) and then remove the element
                setTimeout(() => {
                    item.remove(); // The .remove() method is simple and widely supported
                }, 500); // The delay must match the CSS transition duration
            }
        }

