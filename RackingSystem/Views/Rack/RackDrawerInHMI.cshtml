                        const dot2 = document.getElementById('pDot1');
                        dot2.className = 'step-dot done mt-1';
                    }
                    else {
                        log('Get Put Away Slot :: ' + result.errMessage, 'alert');
                    }
                },
                error: function (error) {
                    log('Get Put Away Slot :: ' + error.val, 'alert');
                }
            });

            return fResult;
        }

