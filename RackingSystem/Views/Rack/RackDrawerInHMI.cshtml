                    });
                    Swal.showLoading()
                },
                success: function (result) {
                    // console.log(result);
                    swal.close();

                    if (result.success == true) {
                        fResult = true;

                        $("#txtTrolleyId").val(result.data.trolleyInfo.trolley_Id);
