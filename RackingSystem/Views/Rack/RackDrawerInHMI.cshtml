@{
    Layout = "~/Views/Shared/_LayoutEmpty.cshtml";
}

<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: 'Outfit', sans-serif;
        margin: 0;
    }

    .tray {
        width: 56px;
        height: 18px;
        border-radius: 3px;
        border: 1.5px solid rgba(0,0,0,0.15);
        transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .arm {
        transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .gripper {
        transition: all 0.3s ease;
    }

    @@keyframes pulse-glow {
        0%, 100% {
            box-shadow: 0 0 8px rgba(16, 185, 129, 0.2);
        }

        50% {
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.4);
        }
    }

    .status-active {
        animation: pulse-glow 1.5s ease-in-out infinite;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .log-entry {
        animation: slideIn 0.3s ease;
    }

    .mono {
        font-family: 'JetBrains Mono', monospace;
    }

    /*.rack-slot {
            width: 62px;
            height: 22px;
            border: 1.5px dashed rgba(0,0,0,0.1);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .rack-slot:hover {
                border-color: #3b82f6;
                box-shadow: 0 0 8px rgba(59, 130, 246, 0.2);
            }

            .rack-slot.rack-selected {
                border-color: #10b981;
                box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
                background: rgba(16, 185, 129, 0.08);
            } */

    .rack-selected {
        border-color: #10b981;
        box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
        background: rgba(16, 185, 129, 0.08);
    }

    .trolley-slot {
        width: 62px;
        height: 22px;
        border: 1.5px dashed rgba(0,0,0,0.1);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .trolley-slot:hover {
            border-color: #3b82f6;
            box-shadow: 0 0 8px rgba(59, 130, 246, 0.2);
        }

        .trolley-slot.empty-selected {
            border-color: #10b981;
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
            background: rgba(16, 185, 129, 0.08);
        }

    .tray.empty-selected {
        background-color: #10b981;
    }

    .scene-container {
        position: relative;
        width: 100%;
        height: 280px;
        border-radius: 12px;
        overflow: hidden;
    }

    .rack-section, .trolley-column {
        display: flex;
        flex-direction: column;
        gap: 1.5px;
        align-items: center;
    }

    .trolley-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5px;
        padding: 8px;
        background: rgba(243, 244, 246, 0.6);
        border-radius: 8px;
        width: fit-content;
    }

    .rack-selector, .trolley-target {
        cursor: pointer;
        border: 2px solid transparent;
        border-radius: 6px;
        transition: all 0.3s ease;
        padding: 8px;
    }

        .rack-selector:hover {
            border-color: #d1d5db;
            background: rgba(209, 213, 219, 0.15);
        }

        .rack-selector.selected {
            border-color: #10b981;
            background: rgba(16, 185, 129, 0.1);
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.2);
        }

    .trolley-target {
        position: relative;
    }

        .trolley-target::after {
            content: '';
            position: absolute;
            inset: 0;
            border: 2px solid transparent;
            border-radius: 4px;
            pointer-events: none;
            transition: all 0.3s ease;
        }

        .trolley-target:hover::after {
            border-color: #3b82f6;
            box-shadow: 0 0 8px rgba(59, 130, 246, 0.2);
        }

        .trolley-target.target-selected::after {
            border-color: #10b981;
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
            background: rgba(16, 185, 129, 0.08);
        }

    .step-line::before {
        content: '';
        position: absolute;
        left: 15px;
        top: 32px;
        bottom: -8px;
        width: 2px;
        background: lightgrey; /* #1e293b; */
    }

    .step-line:last-child::before {
        display: none;
    }

    .step-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid lightgrey; /* #334155; */
        background: lightgrey; /* #0f172a; */
        flex-shrink: 0;
        transition: all 0.3s;
        position: relative;
        z-index: 2;
    }

        .step-dot.active {
            border-color: #22c55e;
            background: #22c55e;
            box-shadow: 0 0 10px rgba(34,197,94,0.5);
        }

        .step-dot.done {
            border-color: #22c55e;
            background: #22c55e;
        }

        .step-dot.waiting {
            border-color: lightgrey; /* #475569; */
            background: lightgrey; /* #1e293b; */
        }

    .status-badge {
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 9999px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .badge-idle {
        background: #1e293b;
        color: #64748b;
    }

    .badge-running {
        background: #052e16;
        color: #4ade80;
    }

    .badge-done {
        background: #022c22;
        color: #34d399;
    }

    .hidden {
        display: none;
    }

    .fade-out {
        opacity: 0;
        /* This transition duration should match the delay in the JavaScript setTimeout */
        transition: opacity 0.5s ease-out;
    }

    .trolley-selected {
        border-color: #10b981;
        box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
        background: rgba(16, 185, 129, 0.08);
    }

    .selected {
        border-color: #10b981;
        box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
        background: rgba(16, 185, 129, 0.08);
    }

</style>

<input type="hidden" id="xToken" value="@ViewBag.xToken" autocomplete="off">
<input type="hidden" id="xQId" value="@ViewBag.QId" autocomplete="off">
<input type="hidden" id="xDeviceId" value="@ViewBag.DeviceId" autocomplete="off">
<input type="hidden" id="xQContinuos" value="@ViewBag.QContinuos" autocomplete="off">
<input type="hidden" id="txtTrolleyId" autocomplete="off">
<input type="hidden" id="txtDtlId" autocomplete="off">

<div id="app" class="h-full w-full overflow-auto" style="background: #f8f9fa;">
    <!-- Title -->
    <header class="px-6 py-4 flex items-center justify-between border-b" style="border-color: #e5e7eb;">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: #10b981;">
                <i class="bi-building-add" style="width:20px;height:20px;color:#fff;"></i>
            </div>
            <div>
                <h1 id="pageTitle" class="text-lg font-bold" style="color:#1f2937;">SRMS</h1>
                <p id="statusLabel" class="text-xs mono" style="color:#6b7280;">Put away empty drawer from Trolley to SRMS</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <div id="statusBadge" class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mono" style="background:#f3f4f6;color:#6b7280;">
                <span id="statusDot" class="w-2 h-2 rounded-full" style="background:#6b7280;"></span> <span id="statusText">IDLE</span>
            </div>
        </div>
    </header>
    <!-- Body -->
    <div class="p-6 flex flex-col gap-4" style="min-height: 90vh;">
        <!-- Scene -->
        <div class="scene-container" style="background: linear-gradient(180deg, #ffffff 0%, #f3f4f6 100%); border: 1px solid #e5e7eb; height: 160px;">
            <!-- Grid overlay -->
            <svg class="absolute inset-0 w-full h-full" style="opacity:0.08;">
                <defs>
                    <pattern id="grid" width="30" height="30" patternunits="userSpaceOnUse">
                        <path d="M 30 0 L 0 0 0 30" fill="none" stroke="#fff" stroke-width="0.5" />
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)" />
            </svg><!-- Left Racks -->
            <div class="absolute left-6 top-10 flex" style="bottom: 16px;">
                <div class="rack-section rack-selector" id="rackLeftSelector">
                    <div class="text-xs mono mb-1" style="color:#374151;">
                        <input type="checkbox" id="chkCol1"  /> <label for="chkCol1"> TROLLEY LEFT</label>
                    </div>
                    <input type="text" id="left-input-tr" class="w-full px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" autocomplete="off">
                    <div class="flex flex-row gap-1.5" id="rackLeftSlots"></div>
                </div><!-- Rack Right -->
                <div class="rack-section rack-selector" id="rackRightSelector">
                    <div class="text-xs mono mb-1" style="color:#374151;">
                        <input type="checkbox" id="chkCol2" /> <label for="chkCol2"> TROLLEY CENTER</label>
                    </div>
                    <input type="text" id="center-input-tr" class="w-full px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" autocomplete="off">
                    <div class="flex flex-row gap-1.5" id="rackRightSlots"></div>
                </div><!-- Rack Right -->
                <div class="rack-section rack-selector" id="rackRightSelector">
                    <div class="text-xs mono mb-1" style="color:#374151;">
                        <input type="checkbox" id="chkCol3" /> <label for="chkCol3"> TROLLEY RIGHT</label>
                    </div>
                    <input type="text" id="right-input-tr" class="w-full px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" autocomplete="off">
                    <div class="flex flex-row gap-1.5" id="rackRightSlots"></div>
                </div>
            </div><!-- PLC Arm Assembly -->
            <div id="armAssembly" class="arm absolute" style="left: 50%; top: 80px; transform: translateX(-50%);">
                <!-- Vertical rail -->
                <div class="absolute top-1/2 -translate-y-1/2" style="width:360px;height:4px;background:#334155;border-radius:2px;left:-30px;">
                    <div style="width:8px;height:8px;background:#475569;border-radius:50%;position:absolute;left:0;top:-2px;"></div>
                    <div style="width:8px;height:8px;background:#475569;border-radius:50%;position:absolute;right:0;top:-2px;"></div>
                </div><!-- Arm head -->
                <div id="armHead" class="absolute arm" style="top:50%;transform:translateY(-50%);left:0;">
                    <div style="width:14px;height:40px;background:#3b82f6;border-radius:4px;margin:0 auto;"></div><!-- Grippers -->
                    <div id="gripperLeft" class="gripper" style="width:16px;height:8px;background:#60a5fa;border-radius:3px 0 0 3px;position:absolute;left:-16px;top:16px;"></div>
                    <div id="gripperRight" class="gripper" style="width:16px;height:8px;background:#60a5fa;border-radius:0 3px 3px 0;position:absolute;right:-16px;top:16px;"></div><!-- Held tray -->
                    <div id="heldTray" class="tray absolute hidden" style="top:50%;transform:translateY(-50%);left:24px;"></div>
                </div>
            </div><!-- Trolley Indicator Light -->
            <div class="absolute right-6 top-10 flex" style="bottom: 16px;">
                <!-- Rack Left -->
                <div class="rack-section rack-selector" id="rackLeftSelector">
                    <div class="text-xs mono mb-1" style="color:#374151;">
                        RACK LEFT
                    </div>
                    <input type="text" id="left-input" class="w-full px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" autocomplete="off">
                    <div class="flex flex-row gap-1.5" id="rackLeftSlots"></div>
                </div><!-- Rack Right -->
                <div class="rack-section rack-selector" id="rackRightSelector">
                    <div class="text-xs mono mb-1" style="color:#374151;">
                        RACK RIGHT
                    </div>
                    <input type="text" id="right-input" class="w-full px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" autocomplete="off">
                    <div class="flex flex-row gap-1.5" id="rackRightSlots"></div>
                </div>
            </div>
        </div>
      
        <div class="grid grid-cols-2 gap-4 p-4" style="min-height: calc(100% - 73px);">
            <!-- Left: System Control (3 cols = 50%) -->
            <div class="col-span-1 flex flex-col gap-4">
                <!-- System Control -->
                <div class="rounded-xl p-6 flex flex-col" style="background:#fff;border:1px solid #e5e7eb;">
                    <h2 class="text-xs font-semibold mb-2 flex items-center gap-2" style="color:#4b5563;">
                        <i class="bi-controller" data-lucide="sliders-horizontal" style="width:14px;height:14px;"></i> System Control
                    </h2>
                    <div class="flex flex-wrap gap-1.5 mb-2">
                        <div class="flex items-center gap-2">
                            <label for="job-input" class="text-xs font-semibold" style="color:#4b5563;white-space:nowrap;">Job : </label>
                            <input type="text" id="job-input" value="@ViewBag.QNo" class="flex-1 px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" disabled>
                        </div>
                        <div class="flex items-center gap-2">
                            <label for="trolley-input" class="text-xs font-semibold" style="color:#4b5563;white-space:nowrap;">Trolley : </label>
                            <input type="text" id="trolley-input" class="flex-1 px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;">
                            <select id="side-input" width="50px;" class="flex-1 px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;">
                                <option id="A">A</option>
                                <option id="B">B</option>
                            </select>
                        </div>
                        <div class="flex items-center gap-2">
                            <label for="chkAutoRun" class="text-xs font-semibold" style="color:#4b5563;white-space:nowrap;">Auto : </label>
                            <input type="checkbox" id="chkAutoRun" style="width:14px;height:14px;cursor:pointer;">
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-1.5 mb-2">
                        <button id="start-btn" class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all" style="background:#10b981;color:#fff;"
                                onclick="systemStart()">
                            <i class="bi-play-fill" style="width:12px;height:12px;"></i> Start
                        </button>
                        <button id="cont-btn" class="hidden flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all" style="background:#f59e0b;color:#fff; "
                                onclick="systemCont()">
                            <i class="bi-pause-fill" style="width:12px;height:12px;"></i> Continuos
                        </button>
                        <button id="stop-btn" class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all" style="background:#e74c3c;color:#fff;"
                                onclick="systemStop()">
                            <i class="bi-stop-fill" style="width:12px;height:12px;"></i> Stop
                        </button>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mb-6">
                        <div class="rounded-lg p-3 text-center" style="background:#fef3c7;border:1px solid #fde68a;">
                            <div class="text-xs mono" style="color:#92400e;">
                                Pending
                            </div>
                            <div id="pendingCount" class="text-2xl font-bold mono" style="color:#f59e0b;">
                                0
                            </div>
                        </div>
                        <div class="rounded-lg p-3 text-center" style="background:#dbeafe;border:1px solid #bfdbfe;">
                            <div class="text-xs mono" style="color:#1e40af;">
                                Completed
                            </div>
                            <div id="completedCount" class="text-2xl font-bold mono" style="color:#3b82f6;">
                                0
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row" style="justify-content: space-between; padding: 10px;">
                    <!-- Retrieve Process Panel -->
                    <div class="rounded-xl p-6 w-1/2" style="background:#ffffff; border:1px solid #e2e8f0; width: 49%;">
                        <h2 class="text-xs font-semibold mb-2 flex items-center gap-2" style="color:#4b5563;">
                            <i class="bi-rocket-takeoff" style="width:14px;height:14px;"></i> Retrieve Process
                        </h2>
                        <div class="mb-6" id="cartesian-session">
                            <div class="flex items-center justify-between mb-3">
                                @* <p class="text-xs font-semibold mono" style="color:#64748b;">GANTRY PROCESS</p> *@
                                <div class="flex gap-2">
                                    <button onclick="startRetrieve()" class="px-3 py-1 rounded text-xs font-semibold" id="btnRetrieveStart" style="background:#16a34a; color:#fff;">
                                        <i class="bi-play-fill" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                        Start
                                    </button>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2" id="retrieveStepsContainer">
                                <div class="step-line relative flex items-start gap-3 py-1">
                                    <div class="step-dot waiting mt-1" id="rDot1"></div>
                                    <div>
                                        <p class="text-sm font-semibold" style="color:#0f172a;">PC → DB Trolley</p>
                                        <p class="text-xs" style="color:#64748b;">Get Trolley Slot</p>
                                    </div>
                                    <button onclick="loadDBCheckRetrieveSlot()" class="px-3 py-1 rounded text-xs font-semibold" style="background:#fff; color:#ef4444;">
                                        <i class="bi-wrench-adjustable" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                    </button>
                                </div>
                                <div class="step-line relative flex items-start gap-3 py-1">
                                    <div class="step-dot waiting mt-1" id="rDot2"></div>
                                    <div>
                                        <p class="text-sm font-semibold" style="color:#0f172a;">Robot → Trolley</p>
                                        <p class="text-xs" style="color:#64748b;">Retrieve</p>
                                    </div>
                                    <button onclick="loadPLCRetrieveTray()" class="px-3 py-1 rounded text-xs font-semibold" style="background:#fff; color:#ef4444;">
                                        <i class="bi-wrench-adjustable" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                    </button>
                                </div>
                                <div class="step-line relative flex items-start gap-3 py-1">
                                    <div class="step-dot waiting mt-1" id="rDot3"></div>
                                    <div>
                                        <p class="text-sm font-semibold" style="color:#0f172a;">Robot → Center</p>
                                        <p class="text-xs" style="color:#64748b;">Retrieve Status</p>
                                    </div>
                                    <button onclick="retry_RetrieveStatus()" class="px-3 py-1 rounded text-xs font-semibold" style="background:#fff; color:#ef4444;">
                                        <i class="bi-wrench-adjustable" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="pt-4 mt-4 border-t" style="border-color:#e2e8f0;">
                                <div class="flex flex-grid items-start gap-3 py-1">
                                    <input type="text" id="txtRetrieveSlot" placeholder="Retrieve Slot" autocomplete="off" class="px-2.5 py-1.5 rounded-lg text-xs border" style="width: 40%;">
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Putaway Steps -->
                    <div class="rounded-xl p-6 w-1/2" style="background:#fff;border:1px solid #e5e7eb; width: 49%;">
                        <h2 class="text-xs font-semibold mb-2 flex items-center gap-2" style="color:#4b5563;">
                            <i class="bi-rocket-takeoff" style="width:14px;height:14px;"></i> Putaway Process
                        </h2>
                        <div class="mb-6" id="trolley-session">
                            <div class="flex items-center justify-between mb-3">
                                @* <p class="text-xs font-semibold mono" style="color:#64748b;">GANTRY PROCESS</p> *@
                                <div class="flex gap-2">
                                    <button onclick="startPutAway()" class="px-3 py-1 rounded text-xs font-semibold" id="btnPutawayStart" style="background:#16a34a; color:#fff;">
                                        <i class="bi-play-fill" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                        Start
                                    </button>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2" id="putAwayStepsContainer">
                                <div class="step-line relative flex items-start gap-3 py-1">
                                    <div class="step-dot waiting mt-1" id="pDot1"></div>
                                    <div>
                                        <p class="text-sm font-semibold" style="color:#0f172a;">PC → DB Slot</p>
                                        <p class="text-xs" style="color:#64748b;">Get Slot</p>
                                    </div>
                                    <button onclick="loadPLCGetEmptySlot()" class="px-3 py-1 rounded text-xs font-semibold" style="background:#fff; color:#ef4444;">
                                        <i class="bi-wrench-adjustable" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                    </button>
                                </div>
                                <div class="step-line relative flex items-start gap-3 py-1">
                                    <div class="step-dot waiting mt-1" id="pDot2"></div>
                                    <div>
                                        <p class="text-sm font-semibold" style="color:#0f172a;">Robot → SRMS</p>
                                        <p class="text-xs" style="color:#64748b;">PutAway</p>
                                    </div>
                                    <button onclick="loadPLCPutAway()" class="px-3 py-1 rounded text-xs font-semibold" style="background:#fff; color:#ef4444;">
                                        <i class="bi-wrench-adjustable" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                    </button>
                                </div>
                                <div class="step-line relative flex items-start gap-3 py-1">
                                    <div class="step-dot waiting mt-1" id="pDot3"></div>
                                    <div>
                                        <p class="text-sm font-semibold" style="color:#0f172a;">Robot → Center</p>
                                        <p class="text-xs" style="color:#64748b;">PutAway Status</p>
                                    </div>
                                    <button onclick="retry_PutAwayStatus()" class="px-3 py-1 rounded text-xs font-semibold" style="background:#fff; color:#ef4444;">
                                        <i class="bi-wrench-adjustable" style="width:12px;height:12px; display:inline; margin-right:4px;"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="pt-4 mt-4 border-t" style="border-color:#e2e8f0;">
                                <div class="flex flex-grid items-start gap-3 py-1">
                                    <input type="text" id="txtPutSlot" placeholder="Put Slot" autocomplete="off" class="px-2.5 py-1.5 rounded-lg text-xs border" style="width: 50%;">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Center: Activity Log (3 cols = 50%) -->
            <div class="col-span-1 flex flex-col gap-4">
                <!-- Activity Log -->
                <div class="rounded-xl p-6 flex flex-col" style="background:#fff;border:1px solid #e5e7eb; height: 100%;">
                    <h2 class="text-xs font-semibold mb-2 flex items-center gap-2" style="color:#4b5563;"><i class="bi-terminal" style="width:14px;height:14px;"></i> Activity Log</h2>
                    <div id="logList" class="space-y-1 overflow-y-auto" style="max-height: 35rem;">
                        <div class="log-entry text-xs" style="color:#64748b;">
                            [System ready]
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="https://cdn.tailwindcss.com/3.4.17"></script>
    <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script> 
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&amp;family=Outfit:wght@400;500;600;700&amp;display=swap" rel="stylesheet">

    <link href="~/css/datatables.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/sweetalert2.min.css">

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/datatables.min.js"></script>
    <script src="~/js/sweetalert2.all.min.js"></script>

    <script type="text/javascript">

        // Centralized state management with system status
        let sharedDrawerState = {
            drawerStatus: 'None', // States: 'Drawer', 'None'
            cartesianRobotState: 'Ready', // 'Ready', 'Retrieving', 'Proceed Put Away'
            cartesianLocation: 'center',
            systemRunning: false, // Overall system run status
            trolleyLocation: 'none', // 'PickedAndHolding', 'Placing', 'Returning'
        };

        var cartesianAutoTimer;
        let inRetrieveMove = false;
        let inPutAwayMove = false;

        let endTask = false;

        let token = '';
        let qId = 0;
        let deviceId = '';
        let qCont = 0;

        let attemptsRetrieve = 1;
        let attemptsPutAway = 1;
        let changeTakeSlot = false;
        let changePutSlot = false;

        let halfRetrieveMoveStep = 1;
        let halfPlaceMoveStep = 1;

        let colNo = 1;

        let totalPending = 0;
        let totalCompleted = 0;

        const jsonModal = document.getElementById("jsonModal");
        const formJSON = document.getElementById("formJSON");

        function closeTab() {
            window.close();
        }

        $(document).ready(function () {
            document.getElementById('chkAutoRun').checked = true;
            disableDivContent(true);
            $("#txtTrolleyId").val('0');
            $("#txtActHeight").val('0');
            updateSystemStatusUI();
            updateJson();

            token = $('#xToken').val();
            qId = Number($('#xQId').val());
            deviceId = $('#xDeviceId').val();
            qCont = $('#xQContinuos').val();

            $("#left-input-tr").val('1');
            $("#center-input-tr").val('1');
            $("#right-input-tr").val('1');

            document.getElementById('chkCol1').checked = true;
            document.getElementById('chkCol2').checked = true;
            document.getElementById('chkCol3').checked = true;

            if (qCont == "1") {
                $('#cont-btn').removeClass('hidden');
                $('#start-btn').addClass('hidden');
                readyContinuos();
            }
        });

        async function showJSONModal() {

            var data = "";

            await $.ajax({
                url: '/api/PLCTrolley/GetRackJobJson',
                type: 'GET',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                dataType: 'JSON',
                contentType: 'application/json; charset=utf-8',
                beforeSend: function () {
                },
                success: function (result) {
                    data = result.data;
                },
                error: function (error) {
                }
            });


            let cols = [ 'SystemStart', 'TrolleyCode', 'TrolleyId', 'TrolleySide', 'DrawerStatus',
            'CartesianRobotState', 'CartesianLocation',
            'RetrieveSlot', 'PutAwaySlot', 'TrolleyLocation', 'ColNum',
            'chkCol1', 'chkCol2', 'chkCol3',
            'CurrentRowCol1', 'CurrentRowCol2', 'CurrentRowCol3' ];

            let columnInputs = '';
            let v = '';

            cols.forEach((column, index) => {
                Object.entries(data).forEach(([key, value]) => {
                  // console.log(`${key}: ${value}`);
                  if (key.toUpperCase() == column.toUpperCase()) {
                      v = value;
                  }
                });

                columnInputs += `
                    <div class="row justify-content-center align-items-center mb-3">
                        <div class="col-5">
                            <label class="form-label mb-0">${column}</label>
                        </div>
                        <div class="col-5">
                            <input type="text" id="col${column}" class="form-modal" value="${v}" />
                        </div>
                    </div>`;
            });


            document.getElementById('jsonColumns').innerHTML = columnInputs;
            $('#jsonModal').modal("show");
        }

        async function updateJSONModal() {

            const chkCol1 = document.getElementById('chkCol1');
            const chkCol2 = document.getElementById('chkCol2');
            const chkCol3 = document.getElementById('chkCol3');

            var data = {
                SystemStart: $("#colSystemStart").val() === "true",

                TrolleyCode: $("#colTrolleyCode").val(),
                TrolleyId: Number($("#colTrolleyId").val()),
                TrolleySide: $("#colTrolleySide").val(),

                DrawerStatus: $("#colDrawerStatus").val(),

                CartesianRobotState: $("#colCartesianRobotState").val(),
                CartesianLocation: $("#colCartesianLocation").val(),

                RetrieveSlot: $("#colRetrieveSlot").val(),
                PutAwaySlot: $("#colPutAwaySlot").val(),

                TrolleyLocation: $("#colTrolleyLocation").val(),

                ColNum: colNo,

                chkCol1: chkCol1.checked,
                chkCol2: chkCol2.checked,
                chkCol3: chkCol3.checked,

                CurrentRowCol1: Number($("#colCurrentRowCol1").val()),
                CurrentRowCol2: Number($("#colCurrentRowCol2").val()),
                CurrentRowCol3: Number($("#colCurrentRowCol3").val()),

            }

            // console.log(data);

            $.ajax({
                url: '/api/PLCTrolley/UpdateRackJobJson',
                type: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                data: JSON.stringify(data),
                dataType: 'JSON',
                contentType: 'application/json; charset=utf-8',
                beforeSend: function () {
                },
                success: function (result) {
                    if (result.success == true) {
                        $("#jsonModal").modal("toggle");
                        getJson();
                    }
                    else {
                        console.log(result.errMessage);
                    }
                },
                error: function (error) {
                    console.log(error);
                }
            });
        }

        // ----------- HMI UI
        function disableDivContent(status) {
            const div2 = document.getElementById('trolley-session');
            if (div2) {
                const interactiveElements = div2.querySelectorAll('button'); // input, select, textarea,
                interactiveElements.forEach(element => {
                    element.setAttribute('disabled', status);
                    if (status == false) {
                        element.removeAttribute('disabled');
                    }
                });
            }

            const div = document.getElementById('cartesian-session');
            if (div) {
                const interactiveElements = div.querySelectorAll('button'); // input, select, textarea,
                interactiveElements.forEach(element => {
                    element.setAttribute('disabled', status);
                    if (status == false) {
                        element.removeAttribute('disabled');
                    }
                });
            }

        }

        // Function to update the main header status text and button states
        function updateSystemStatusUI() {
            const startBtn = document.getElementById('start-btn');
            const stopBtn = document.getElementById('stop-btn');
            const contBtn = document.getElementById('cont-btn');

            const badge = document.getElementById('statusBadge');
            const dot = document.getElementById('statusDot');
            const st = document.getElementById('statusText');

            if (sharedDrawerState.systemRunning) {
                st.textContent = 'PROCESSING';
                dot.style.background = '#f59e0b';
                badge.classList.add('status-active');

                startBtn.disabled = true;
                contBtn.disabled = true;
                stopBtn.disabled = false;
            } else {
                st.textContent = 'STOPPED';
                dot.style.background = "#f59e0b";
                badge.classList.remove('status-active');

                startBtn.disabled = false;
                contBtn.disabled = false;
                stopBtn.disabled = true;
            }
        }

        function updateCartesianUIState() {
            document.querySelector('#left-input').classList.remove('selected');
            document.querySelector('#right-input').classList.remove('selected');

            if (sharedDrawerState.cartesianLocation === 'left') {
                document.querySelector('#left-input').classList.add('selected');
            } else if (sharedDrawerState.cartesianLocation === 'right') {
                document.querySelector('#right-input').classList.add('selected');
            } else {
                $("#left-input").val('');
                $("#right-input").val('');
            }

        }

        function updateTrolleyUIState() {
            document.querySelector('#left-input-tr').classList.remove('trolley-selected');
            document.querySelector('#center-input-tr').classList.remove('trolley-selected');
            document.querySelector('#right-input-tr').classList.remove('trolley-selected');

            if (sharedDrawerState.trolleyLocation === 'left') {
                document.querySelector('#left-input-tr').classList.add('trolley-selected');
            } else if (sharedDrawerState.trolleyLocation === 'right') {
                document.querySelector('#right-input-tr').classList.add('trolley-selected');
            } else if (sharedDrawerState.trolleyLocation === 'center') {
                document.querySelector('#center-input-tr').classList.add('trolley-selected');
            } else {
                // $("#txtTrolleySlot").val('');
            }
        }

        function updateDash() {
            document.getElementById('pendingCount').innerHTML = totalPending;
            document.getElementById('completedCount').innerHTML = totalCompleted;
        }

        // ----------- Main Action
        async function readyContinuos() {
            var data = await getJson();
            // console.log(data);

            if (data == true) {
                await getTrolley($("#trolley-input").val(), true);

                // console.log(sharedDrawerState);

                // updateSystemStatusUI();
                updateTrolleyUIState();
                updateCartesianUIState();

            }
        }

        // System Start Handler
        async function systemStart() {
            if (sharedDrawerState.systemRunning) return;

            // checking is loader valid and get loader info
            var tr = $("#trolley-input").val();
            if (tr == undefined) {
                log('Trolley :: Please scan Trolley', 'alert');
                return;
            }
            if (tr == '') {
                log('Trolley :: Please scan Trolley', 'alert');
                return;
            }
            var ok = await getTrolley(tr, false);
            if (ok == false) {
                return;
            }

            // 3. Continue UI
            disableDivContent(false);

            sharedDrawerState.systemRunning = true;
            updateSystemStatusUI();
            // log("System Start command issued.", 'alert');

             updateJson();

            // 4. Continue
             cartesianAutoTimer = setInterval(cartesianAuto, 3000); //3 second workout

        }

        // System Continue Handler
        async function systemCont() {

            // 3. Continue UI
            disableDivContent(false);

            // updateActiveColumn(colNum);

            sharedDrawerState.systemRunning = true;
            updateSystemStatusUI();

            // 4. Continue
             cartesianAutoTimer = setInterval(cartesianAuto, 3000); //3 second workout

        }

        // System Stop Handler
        function systemStop() {
            if (!sharedDrawerState.systemRunning) return;
            sharedDrawerState.systemRunning = false;
            updateSystemStatusUI();
            // log("System Stop command issued. System idling.", 'alert');

            updateJson();

            clearInterval(cartesianAutoTimer);

        }

        function delay(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        // ----------- Log
        function log(msg, typ) {
          const list = document.getElementById('logList');
          const d = document.createElement('div');
          d.className = 'log-entry';
          const ts = new Date().toLocaleTimeString('en',{hour12:false});
          if (typ == 'info') {
            d.innerHTML = `<span style="color:#475569">[${ts}]</span> ${msg}`;
          }
          if (typ == 'alert') {
            d.innerHTML = `<span style="color:#e74c3c">[${ts}]</span> <span style="color:#e74c3c">${msg} </span>`;
          }
          list.prepend(d);
          if (list.children.length > 30) list.lastChild.remove();
        }

        // ----------- HMI Action
        function updateJson() {
            const chkCol1 = document.getElementById('chkCol1');
            const chkCol2 = document.getElementById('chkCol2');
            const chkCol3 = document.getElementById('chkCol3');

            var data = {
                SystemStart: sharedDrawerState.systemRunning,

                TrolleyCode: $("#trolley-input").val(),
                TrolleyId: Number($("#txtTrolleyId").val()),
                TrolleySide: $('#side-input').val(),

                DrawerStatus: sharedDrawerState.drawerStatus,

                CartesianRobotState: sharedDrawerState.cartesianRobotState,
                CartesianLocation: sharedDrawerState.cartesianLocation,

                RetrieveSlot: $("#txtRetrieveSlot").val(),
                PutAwaySlot: $("#txtPutSlot").val(),

                TrolleyLocation: sharedDrawerState.trolleyLocation,

                ColNum: colNo,

                chkCol1: chkCol1.checked,
                chkCol2: chkCol2.checked,
                chkCol3: chkCol3.checked,

                CurrentRowCol1: Number($('#left-input-tr').val()),
                CurrentRowCol2: Number($('#center-input-tr').val()),
                CurrentRowCol3: Number($('#right-input-tr').val()),
            }

            $.ajax({
                url: '/api/PLCTrolley/UpdateRackJobJson',
                type: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                data: JSON.stringify(data),
                dataType: 'JSON',
                contentType: 'application/json; charset=utf-8',
                beforeSend: function () {
                },
                success: function (result) {
                    if (result.success == true) {
                    }
                    else {
                        console.log(result.errMessage);
                    }
                },
                error: function (error) {
                    console.log(error);
                }
            });
        }

        async function getJson() {
            var fResult = false;

            await $.ajax({
                url: '/api/PLCTrolley/GetRackJobJson',
                type: 'GET',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                dataType: 'JSON',
                contentType: 'application/json; charset=utf-8',
                beforeSend: function () {
                },
                success: function (result) {
                    sharedDrawerState.systemRunning = result.data.systemRunning;

                    $("#trolley-input").val(result.data.trolleyCode);
                    $("#txtTrolleyId").val(result.data.trolleyId);
                    $("#side-input").val(result.data.trolleySide);

                    sharedDrawerState.drawerStatus = result.data.drawerStatus;

                    sharedDrawerState.cartesianRobotState = result.data.cartesianRobotState;
                    sharedDrawerState.cartesianLocation = result.data.cartesianLocation;

                    $("#txtRetrieveSlot").val(result.data.retrieveSlot);
                    $("#txtPutSlot").val(result.data.putAwaySlot);

                    sharedDrawerState.trolleyLocation = result.data.trolleyLocation;

                    colNo = result.data.colNum;

                    document.getElementById('chkCol1').checked = result.data.chkCol1;
                    document.getElementById('chkCol2').checked = result.data.chkCol2;
                    document.getElementById('chkCol3').checked = result.data.chkCol3;

                    $("#left-input-tr").val(result.data.currentRowCol1);
                    $("#center-input-tr").val(result.data.currentRowCol2);
                    $("#right-input-tr").val(result.data.currentRowCol3);

                    fResult = true;

                    return fResult;
                },
                error: function (error) {
                    console.log(error);
                }
            });

            return fResult;
        }

        // ----------- Action (Auto Mode)
        function cartesianAuto() {
            if (endTask == true) { return; }

            const chkAutoRun = document.getElementById('chkAutoRun');
            if (chkAutoRun.checked) {
                // 1. if no drawer just take (reelId MUST have first cause need get actual height)
                if (sharedDrawerState.systemRunning == true && sharedDrawerState.drawerStatus == "None" && inRetrieveMove == false && inPutAwayMove == false) {
                    startRetrieve();
                }

                // 2. if have drawer and placed then just put away
                if (sharedDrawerState.systemRunning == true && sharedDrawerState.drawerStatus == "Drawer" && inRetrieveMove == false && inPutAwayMove == false) {
                    startPutAway();
                }

            }
        }

        // Cartesian Start Retrieve Empty Drawer
        async function startRetrieve() {
            if (inRetrieveMove == true) {
                return;
            }
            if (sharedDrawerState.systemRunning != true) {
                log(`System not yet start.`, 'alert');
                return;
            }
            // if (sharedDrawerState.cartesianRobotState == "Retrieving") {
            //     var chkStatus = await loadPLCGetRetrieveTrayStatus();
            //     if (chkStatus == false) {
            //     }
            //     else {
            //         attemptsRetrieve = 1;

            //         totalReels = totalReels - 1;

            //         sharedDrawerState.drawerStatus = "Drawer";
            //         sharedDrawerState.cartesianRobotState = 'Retrieved';
            //         sharedDrawerState.cartesianLocation = '';
            //         updateCartesianUIState();
            //         updateTrolleyUIState();
            //         log(`Cartesian cycle end: Retrieved.`, 'info');
            //         inRetrieveMove = false;

            //         updateJson();
            //     }
            //     return;
            // }
            if (sharedDrawerState.cartesianRobotState != "Ready") {
                log(`Cartesian is ${sharedDrawerState.cartesianRobotState}, please check.`, 'alert');
                return;
            }
            if (sharedDrawerState.drawerStatus != "None") {
                log(`Cartesian has tray on hold, please check.`, 'alert');
                return;
            }

            sharedDrawerState.cartesianRobotState = 'Retrieving';
            log(`-----------------------------------------------`, 'info');
            log(`Cartesian cycle started: Retrieve Empty Drawer.`, 'info');
            inRetrieveMove = true;

            const chkCol1 = document.getElementById('chkCol1');
            const chkCol2 = document.getElementById('chkCol2');
            const chkCol3 = document.getElementById('chkCol3');

            if (colNo == 1 && Number($('#left-input-tr').val()) >= 51) {
                colNo = 2;

            }
            if (colNo == 1 && chkCol1.checked == false) {
                colNo = 2;
            }
            if (colNo == 2 && Number($('#center-input-tr').val()) >= 51) {
                colNo = 3;
            }
            if (colNo == 2 && chkCol2.checked == false) {
                colNo = 3;
            }
            if (colNo == 3 && Number($('#right-input-tr').val()) >= 51) {
                log(`Trolley is done retrieve, please change another side.`, 'alert');
                loadDBEnd();
                systemStop();
                $('#jobDoneModal').modal('show');
                return;
            }
            if (colNo == 3 && chkCol3.checked == false) {
                log(`Trolley is done retrieve, please change another side.`, 'alert');
                loadDBEnd();
                systemStop();
                $('#jobDoneModal').modal('show');
                return;
            }

            sharedDrawerState.trolleyLocation = 'left';
            if (colNo == 2) { sharedDrawerState.trolleyLocation = 'center'; }
            if (colNo == 3) { sharedDrawerState.trolleyLocation = 'right'; }


            changeTakeSlot = false;

            updateTrolleyUIState();
            updateCartesianUIState();

            var chkSlot = await loadDBCheckRetrieveSlot();
            if (chkSlot == false) {
                sharedDrawerState.cartesianRobotState = 'Ready';
                inRetrieveMove = false;
                updateJson();
                return;
            }

            if (halfRetrieveMoveStep<=1) {
                var getSlot = await loadPLCRetrieveTray();
                if (getSlot == false) {
                    sharedDrawerState.cartesianRobotState = 'Ready';
                    inRetrieveMove = false;
                    updateJson();
                    return;
                }
                await delay(2000);
                halfRetrieveMoveStep = 2;
            }

            var chkStatus = await loadPLCGetRetrieveTrayStatus();
            if (chkStatus == -1) {
                sharedDrawerState.cartesianRobotState = 'Ready';
                inRetrieveMove = false;
                changeTakeSlot = true;

                if (attemptsRetrieve > 3) {
                    log('Retrieve Empty Drawer :: Tried ' + (attemptsRetrieve - 1) + ', auto stop now.', 'info');
                    document.getElementById('chkAutoRun').checked = false;
                    return false;
                }

                return;
            }
            else if (chkStatus == 1) {
                sharedDrawerState.cartesianRobotState = 'Ready';
                log(`Cartesian cycle end: Next Row.`, 'info');
                inRetrieveMove = false;
                changeTakeSlot = false;
                attemptsRetrieve = 1;
                halfRetrieveMoveStep = 1;
                updateJson();
                return;
            }

            attemptsRetrieve = 1;
            halfRetrieveMoveStep = 1;

            sharedDrawerState.drawerStatus = "Drawer";
            sharedDrawerState.cartesianRobotState = 'Retrieved';
            sharedDrawerState.cartesianLocation = '';
            updateCartesianUIState();
            updateTrolleyUIState();
            log(`Cartesian cycle end: Retrieved.`, 'info');
            inRetrieveMove = false;

            updateJson();
        }

        // Cartesian Start Put Away
        async function startPutAway() {
            if (inPutAwayMove == true) {
                return;
            }
            if (sharedDrawerState.systemRunning != true) {
                log(`System not yet start.`, 'alert');
                return;
            }
            if (sharedDrawerState.cartesianRobotState != "Retrieved") {
                log(`Cartesian is ${sharedDrawerState.cartesianRobotState}, please check.`, 'alert');
                return;
            }
            if (sharedDrawerState.drawerStatus != "Drawer") {
                log(`Cartesian not yet get tray, please check.`, 'alert');
                return;
            }

            sharedDrawerState.cartesianRobotState = 'In Put Away';
            log(`Cartesian cycle started: Put Away Reel.`, 'info');
            inPutAwayMove = true;

            var getSlotCode = await loadPLCGetEmptySlot();
            if (getSlotCode == false) {
                sharedDrawerState.cartesianRobotState = 'Retrieved';
                inPutAwayMove = false;
                updateJson();
                return;
            }

            changePutSlot = false;

            updateCartesianUIState();

            if (halfPlaceMoveStep<=1) {
                var getSlot = await loadPLCPutAway();
                if (getSlot == false) {
                    sharedDrawerState.cartesianRobotState = 'Retrieved';
                    inPutAwayMove = false;
                    updateJson();
                    return;
                }
                await delay(3000);
                halfPlaceMoveStep = 2;
            }

            var chkStatus = await loadPLCGetPutAwayStatus();
            if (chkStatus == false) {
                sharedDrawerState.cartesianRobotState = 'Retrieved';
                inPutAwayMove = false;
                changePutSlot = true;

                if (attemptsPutAway > 3) {
                    log('Put Away Drawer :: Tried ' + (attemptsPutAway - 1) + ', auto stop now.', 'info');
                    document.getElementById('chkAutoRun').checked = false;
                    return false;
                }

                return;
            }

            attemptsPutAway = 1;
            halfPlaceMoveStep = 1;

            sharedDrawerState.cartesianRobotState = 'Ready';
            sharedDrawerState.cartesianLocation = '';
            sharedDrawerState.trolleyLocation = '';
            updateCartesianUIState();
            updateTrolleyUIState();

            sharedDrawerState.drawerStatus = "None";
            log(`Cartesian cycle end: Put Away Done.`, 'info');
            inPutAwayMove = false;

            // means all is out
            if (colNo == 3 && Number($('#left-input-tr').val()) >= 0) {
                loadDBEnd();
                systemStop();
            }


            updateJson();
        }


        // ----------- Action :: retry
        async function retry_RetrieveStatus() {
            var chkStatus = await loadPLCGetRetrieveTrayStatus();
            if (chkStatus == -1) {
                sharedDrawerState.cartesianRobotState = 'Ready';
                inRetrieveMove = false;
                changeTakeSlot = true;

                return;
            }
            else if (chkStatus == 1) {
                sharedDrawerState.cartesianRobotState = 'Ready';
                log(`Cartesian cycle end: Next Row.`, 'info');
                inRetrieveMove = false;
                changeTakeSlot = false;
                attemptsRetrieve = 1;
                updateJson();
                return;
            }

            attemptsRetrieve = 1;

            sharedDrawerState.drawerStatus = "Drawer";
            sharedDrawerState.cartesianRobotState = 'Retrieved';
            sharedDrawerState.cartesianLocation = '';
            updateCartesianUIState();
            updateTrolleyUIState();
            log(`Cartesian cycle end: Retrieved.`, 'info');
            inRetrieveMove = false;

            updateJson();

        }

        async function retry_PutAwayStatus() {
            var chkStatus = await loadPLCGetPutAwayStatus();
            if (chkStatus == false) {
                sharedDrawerState.cartesianRobotState = 'Retrieved';
                inPutAwayMove = false;
                changePutSlot = true;
                return;
            }

            attemptsPutAway = 1;

            sharedDrawerState.cartesianRobotState = 'Ready';
            sharedDrawerState.cartesianLocation = '';
            sharedDrawerState.trolleyLocation = '';
            updateCartesianUIState();
            updateTrolleyUIState();

            sharedDrawerState.drawerStatus = "None";
            log(`Cartesian cycle end: Put Away Done.`, 'info');
            inPutAwayMove = false;

            // means all is out
            if (colNo == 3 && Number($('#left-input-tr').val()) >= 0) {
                loadDBEnd();
                systemStop();
            }

            updateJson();
        }


        // ----------- Database
        async function loadDBCheckRetrieveSlot() {

            var s = $('#side-input').val();
            var tr = $("#txtTrolleyId").val();
