@{
    Layout = "~/Views/Shared/_LayoutEmpty.cshtml";
}

<style>
    * {
        box-sizing: border-box;
    }

    :root {
        --bg-main: #2c3e50;
        --text-color: #ecf0f1;
        --accent-color: #3498db;
        --status-ok: #2ecc71;
        --status-alarm: #e74c3c;
        --card-bg: #34495e;
    }

    body {
        font-family: 'Outfit', sans-serif;
        margin: 0;
    }

    .tray {
        width: 56px;
        height: 18px;
        border-radius: 3px;
        border: 1.5px solid rgba(0,0,0,0.15);
        transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .arm {
        transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .gripper {
        transition: all 0.3s ease;
    }

    @@keyframes pulse-glow {
        0%, 100%

    {
        box-shadow: 0 0 8px rgba(16, 185, 129, 0.2);
    }

    50% {
        box-shadow: 0 0 20px rgba(16, 185, 129, 0.4);
    }

    }

    .status-active {
        animation: pulse-glow 1.5s ease-in-out infinite;
    }

    @@keyframes slideIn {
        from

    {
        opacity: 0;
        transform: translateY(8px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .log-entry {
        animation: slideIn 0.3s ease;
    }

    .mono {
        font-family: 'JetBrains Mono', monospace;
    }

    .rack-slot {
        width: 62px;
        height: 22px;
        border: 1.5px dashed rgba(0,0,0,0.1);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .rack-slot:hover {
            border-color: #3b82f6;
            box-shadow: 0 0 8px rgba(59, 130, 246, 0.2);
        }

        .rack-slot.tray-selected {
            border-color: #10b981;
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
            background: rgba(16, 185, 129, 0.08);
        }

    .trolley-slot {
        width: 62px;
        height: 22px;
        border: 1.5px dashed rgba(0,0,0,0.1);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .trolley-slot:hover {
            border-color: #3b82f6;
            box-shadow: 0 0 8px rgba(59, 130, 246, 0.2);
        }

        .trolley-slot.empty-selected {
            border-color: #10b981;
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
            background: rgba(16, 185, 129, 0.08);
        }

    .scene-container {
        position: relative;
        width: 100%;
        height: 400px;
        border-radius: 12px;
        overflow: hidden;
    }

    .rack-section, .trolley-column {
        display: flex;
        flex-direction: column;
        gap: 1.5px;
        align-items: center;
    }

    .trolley-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5px;
        padding: 8px;
        background: rgba(243, 244, 246, 0.6);
        border-radius: 8px;
    }

    .rack-selector, .trolley-target {
        cursor: pointer;
        border: 2px solid transparent;
        border-radius: 6px;
        transition: all 0.3s ease;
        padding: 8px;
    }

        .rack-selector:hover {
            border-color: #d1d5db;
            background: rgba(209, 213, 219, 0.15);
        }

        .rack-selector.selected {
            border-color: #10b981;
            background: rgba(16, 185, 129, 0.1);
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.2);
        }

    .trolley-target {
        position: relative;
    }

        .trolley-target::after {
            content: '';
            position: absolute;
            inset: 0;
            border: 2px solid transparent;
            border-radius: 4px;
            pointer-events: none;
            transition: all 0.3s ease;
        }

        .trolley-target:hover::after {
            border-color: #3b82f6;
            box-shadow: 0 0 8px rgba(59, 130, 246, 0.2);
        }

        .trolley-target.target-selected::after {
            border-color: #10b981;
            box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
            background: rgba(16, 185, 129, 0.08);
        }


    .panel {
        width: 90%;
        max-width: 200px;
        background: linear-gradient(135deg, #ffffff 0%, #f9f9f9 100%);
        border-radius: 5px;
        border: 1px solid rgba(6, 182, 212, 0.5);
        /* box-shadow: 0 8px 32px rgba(6, 182, 212, 0.15); */
        overflow: hidden;
        display: flex;
        flex-direction: column;
        /* animation: fadeIn 0.6s ease-out; */
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* --- Gantry Specific Styles --- */
    .process-visualization {
        display: flex;
        align-items: center;
        justify-content: space-around;
        margin-top: 20px;
        padding: 20px;
        /* background-color: var(--bg-main); */
        border-radius: 8px;
        min-height: 265px;
    }

    .station {
        text-align: center;
        width: 150px;
    }

    .gantry-path {
        flex-grow: 1;
        height: 10px;
        background-color: rgba(6, 182, 212, 0.5);
        position: relative;
        margin: 0 20px;
    }

    .gantry-head {
        border-radius: 50%;
        width: 30px;
        height: 30px;
        background-color: var(--accent-color);
        position: absolute;
        top: -10px;
        transition: left 2s ease-in-out, background-color 0.3s;
    }

        .gantry-head[data-position="loader"] {
            left: 0%;
        }

        .gantry-head[data-position="pickup"] {
            left: 100%;
            transform: translateX(-100%);
        }

        .gantry-head[data-has-reel="true"] {
            background-color: var(--status-ok);
        }

    /* Loader Viewport acts as a mask/window */
    .loader-viewport {
        width: 100%;
        overflow: hidden;
        margin-top: 10px;
    }

    /* Loader Track holds all columns and moves */
    .loader-track {
        display: flex;
        width: 100%;
        transition: transform 0.8s ease-in-out; /* Smooth sliding animation */
    }

        /* When the loader track has this class, we apply a dimming effect */
        .loader-track.picking-dim .col {
            opacity: 0.4;
            transition: opacity 0.3s ease-in-out;
        }

            /* The actively selected column should remain fully visible */
            .loader-track.picking-dim .col.active-pick {
                opacity: 1.0;
            }

            /* Ensure the reel counts and labels within dimmed columns are still somewhat readable */
            .loader-track.picking-dim .col * {
                /* Optional: Maintain slightly higher visibility for text elements */
                /* opacity: 1.0; */
            }

    /* Individual columns within the track */
    .col {
        width: 25%;
        flex-shrink: 0;
        /* background-color: var(--bg-main); */
        border: 2px solid rgba(6, 182, 212, 0.5);
        padding: 5px;
        border-radius: 5px;
        position: relative;
        text-align: center;
    }

    .col-label {
        display: block;
        font-size: 0.8em;
        margin-bottom: 5px;
    }

    .reel {
        width: 100%;
        height: 40px;
        background-color: #95a5a6;
        border-radius: 5px;
        transition: background-color 0.3s;
    }

    .col[data-status="full"] {
        border-color: var(--status-ok);
    }

    .col[data-status="empty"] {
        /* border-color: var(--status-alarm); */
        border-color: grey;
    }

    .col[data-status="full"] .reel {
        background-color: #7f8c8d;
    }

    .col[data-status="empty"] .reel {
        display: none;
    }

    .col[data-status="empty"] {
        padding-top: 20px;
        padding-bottom: 20px;
    }

    .reel-count {
        display: block;
        margin-top: 5px;
        font-size: 0.9em;
        font-weight: bold;
        color: var(--text-color);
    }

        .reel-count[data-count="0"] {
            /* color: var(--status-alarm); */
            color: grey;
        }

    /* Define the position classes managed by JavaScript */
    .loader-track.pos-col-1 {
        transform: translateX(0%);
    }

    .loader-track.pos-col-2 {
        transform: translateX(-25%);
    }

    .loader-track.pos-col-3 {
        transform: translateX(-50%);
    }

    .loader-track.pos-col-4 {
        transform: translateX(-75%);
    }


    /* Loader Battery Display (Single instance) */
    .loader-battery-display {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
    }

        .loader-battery-display .battery-container {
            width: 80px;
            height: 15px;
            background-color: rgba(6, 182, 212, 0.3);
            border: 1px solid var(--text-color);
            border-radius: 3px;
            overflow: hidden;
        }

        .loader-battery-display .battery-level {
            height: 100%;
            background-color: rgba(6, 182, 212, 0.8);
            transition: width 0.5s ease-in-out, background-color 0.5s;
        }

        .loader-battery-display .battery-text {
            font-size: 0.9em;
            font-weight: bold;
            margin-left: 10px;
            color: var(--text-color);
        }

        .loader-battery-display .battery-critical {
            background-color: var(--status-alarm) !important;
        }

        .loader-battery-display .battery-low {
            background-color: #f1c40f !important;
        }


    /* Drawer Station */
    .drawer-station {
        width: 200px;
    }

    .drawer {
        width: 100%;
        height: 60px;
        /* background-color: var(--bg-main); */
        border: 1px solid lightgrey;
        border-radius: 5px;
        margin-top: 10px;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .reel-on-drawer {
        width: 90%;
        height: 40px;
        background-color: transparent;
        border-radius: 5px;
        transition: background-color 0.3s;
    }

    .drawer[data-status="Placed"] .reel-on-drawer {
        background-color: #7f8c8d;
    }

    .drawer[data-status="None"] {
        /* border-color: var(--status-alarm); */
        border-color: grey;
    }

    .drawer[data-status="Drawer"] {
        /* border-color: var(--status-alarm); */
        border-color: var(--status-ok);
    }

    .drawer[data-status="Placed"] {
        border-color: var(--status-alarm);
        /* background-color: #5d6d7e; */
    }

    #drawer-status-text.unavailable, #fork-status-text.unavailable {
        color: var(--status-alarm);
        font-weight: bold;
    }

    .step-line::before {
        content: '';
        position: absolute;
        left: 15px;
        top: 32px;
        bottom: -8px;
        width: 2px;
        background: lightgrey; /* #1e293b; */
    }

    .step-line:last-child::before {
        display: none;
    }

    .step-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid lightgrey; /* #334155; */
        background: lightgrey; /* #0f172a; */
        flex-shrink: 0;
        transition: all 0.3s;
        position: relative;
        z-index: 2;
    }

        .step-dot.active {
            border-color: #22c55e;
            background: #22c55e;
            box-shadow: 0 0 10px rgba(34,197,94,0.5);
        }

        .step-dot.done {
            border-color: #22c55e;
            background: #22c55e;
        }

        .step-dot.waiting {
            border-color: lightgrey; /* #475569; */
            background: lightgrey; /* #1e293b; */
        }

    .status-badge {
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 9999px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .badge-idle {
        background: #1e293b;
        color: #64748b;
    }

    .badge-running {
        background: #052e16;
        color: #4ade80;
    }

    .badge-done {
        background: #022c22;
        color: #34d399;
    }


</style>

<input type="hidden" id="xToken" value="@ViewBag.xToken" autocomplete="off">
<input type="hidden" id="xQId" value="@ViewBag.QId" autocomplete="off">
<input type="hidden" id="xDeviceId" value="@ViewBag.DeviceId" autocomplete="off">
<input type="hidden" id="xQContinuos" value="@ViewBag.QContinuos" autocomplete="off">

<input type="hidden" id="txtSetUnload" autocomplete="off">
<input type="hidden" id="txtLoaderId" autocomplete="off">
<input type="hidden" id="txtCol1TotalReels" autocomplete="off">
<input type="hidden" id="txtCol2TotalReels" autocomplete="off">
<input type="hidden" id="txtCol3TotalReels" autocomplete="off">
<input type="hidden" id="txtCol4TotalReels" autocomplete="off">

<div id="app" class="h-full w-full overflow-auto" style="background: #f8f9fa;">
    <!-- Title -->
    <header class="px-6 py-4 flex items-center justify-between border-b" style="border-color: #e5e7eb;">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: #10b981;">
                <i class="bi-building-add" style="width:20px;height:20px;color:#fff;"></i>
            </div>
            <div>
                <h1 id="pageTitle" class="text-lg font-bold" style="color:#1f2937;">SRMS</h1>
                <p id="statusLabel" class="text-xs mono" style="color:#6b7280;">Put away reels from Auto Loader to SRMS</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <div id="statusBadge" class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mono" style="background:#f3f4f6;color:#6b7280;">
                <span id="statusDot" class="w-2 h-2 rounded-full" style="background:#6b7280;"></span> <span id="statusText">IDLE</span>
            </div>
        </div>
    </header>
    <!-- Body -->
    <div class="p-6 flex gap-4" style="min-height: 30vh;">
        <!-- Scene -->
        <div class="scene-container" style="background: linear-gradient(180deg, #ffffff 0%, #f3f4f6 100%); border: 1px solid #e5e7eb; height: 300px; width:50%;">
            <!-- Grid overlay -->
            <svg class="absolute inset-0 w-full h-full" style="opacity:0.08;">
                <defs>
                    <pattern id="grid" width="30" height="30" patternunits="userSpaceOnUse">
                        <path d="M 30 0 L 0 0 0 30" fill="none" stroke="#fff" stroke-width="0.5" />
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)" />
            </svg>

            <div class="process-visualization">
                <!-- Loader Section (Left Point) -->
                <div class="station loader">
                    <h4>Auto Loader</h4>
                    <div class="loader-viewport">
                        <!-- The inner track that moves left or right -->
                        <div class="loader-track picking-dim">
                            <div class="col" id="col-1" data-status="full"><span class="col-label">C1</span><div class="reel"></div><span class="reel-count" data-count="0">- left</span></div>
                            <div class="col" id="col-2" data-status="full"><span class="col-label">C2</span><div class="reel"></div><span class="reel-count" data-count="0">- left</span></div>
                            <div class="col" id="col-3" data-status="full"><span class="col-label">C3</span><div class="reel"></div><span class="reel-count" data-count="0">- left</span></div>
                            <div class="col" id="col-4" data-status="full"><span class="col-label">C4</span><div class="reel"></div><span class="reel-count" data-count="0">- left</span></div>
                        </div>
                    </div>
                    @* <p>Next Pick: Column <span id="next-pick-col">1</span></p> *@
                    <br />
                    <div class="loader-battery-display">
                        <div class="battery-container">
                            <div class="battery-level" id="loader-battery-level" data-percent="80" style="width: 80%;"></div>
                        </div>
                        <span class="battery-text" id="loader-battery-text">- %</span>
                    </div>
                </div>

                <!-- Gantry Path Visual -->
                <div class="gantry-path">
                    <div class="gantry-head" data-position="loader" data-has-reel="false"></div>
                    <br />
                    <span id="txtReel">Reel : -</span>
                </div>

                <!-- Drawer/Placement Section (Right Point & Interface) -->
                <div class="station drawer-station">

                    <h4>Place on Drawer</h4>
                    <div class="drawer" data-status="None">
                        <div class="reel-on-drawer"></div>
                    </div>
                    <p> <span id="drawer-status-text">No Drawer</span></p>
                    @* <p>Fork Status: <span id="fork-status-text">Retracted</span></p>  Awaiting Place Command *@
                    <div id="gantry-hold-status">
                        🚨 Reel Picked!🚨
                    </div>
                    <br />
                </div>
            </div>
        </div>
        <!-- Scene -->
        <div class="scene-container" style="background: linear-gradient(180deg, #ffffff 0%, #f3f4f6 100%); border: 1px solid #e5e7eb; height: 300px; width:50%;">
            <!-- Grid overlay -->
            <svg class="absolute inset-0 w-full h-full" style="opacity:0.08;">
                <defs>
                    <pattern id="grid" width="30" height="30" patternunits="userSpaceOnUse">
                        <path d="M 30 0 L 0 0 0 30" fill="none" stroke="#fff" stroke-width="0.5" />
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)" />
            </svg>
            <!-- Left Racks -->
            <div class="absolute left-6 top-10 flex" style="bottom: 16px;">
                <div class="rack-section rack-selector" id="rackLeftSelector">
                    <div class="text-xs mono mb-1" style="color:#374151;">
                        RACK LEFT
                    </div>
                    <input type="text" id="left-input" class="w-full px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" autocomplete="off">
                    <div class="flex flex-row gap-1.5" id="rackLeftSlots"></div>
                </div>
            </div>
            <!-- PLC Arm Assembly -->
            <div id="armAssembly" class="arm absolute" style="left: 50%; top: 80px; transform: translateX(-50%);">
                <!-- Vertical rail -->
                <div class="absolute left-1/2 -translate-x-1/2" style="width:4px;height:80px;background:#334155;border-radius:2px;top:-30px;">
                    <div style="width:8px;height:8px;background:#475569;border-radius:50%;position:absolute;top:0;left:-2px;"></div>
                    <div style="width:8px;height:8px;background:#475569;border-radius:50%;position:absolute;bottom:0;left:-2px;"></div>
                </div>
                <!-- Arm head -->
                <div id="armHead" class="absolute arm" style="left:50%;transform:translateX(-50%);top:0;">
                    <div style="width:40px;height:14px;background:#3b82f6;border-radius:4px;margin:0 auto;"></div>
                    <!-- Grippers -->
                    <div id="gripperLeft" class="gripper" style="width:8px;height:16px;background:#60a5fa;border-radius:0 0 3px 3px;position:absolute;left:4px;top:14px;"></div>
                    <div id="gripperRight" class="gripper" style="width:8px;height:16px;background:#60a5fa;border-radius:0 0 3px 3px;position:absolute;right:4px;top:14px;"></div><!-- Held tray -->
                    <div id="heldTray" class="tray absolute hidden" style="left:50%;transform:translateX(-50%);top:28px;"></div>
                </div>
            </div>
            <!-- Trolley Indicator Light -->
            <div class="absolute right-6 top-10 flex" style="bottom: 16px;">
                <div class="rack-section rack-selector" id="rackLeftSelector">
                    <div class="text-xs mono mb-1" style="color:#374151;">
                        RACK RIGHT
                    </div>
                    <input type="text" id="right-input" class="w-full px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" autocomplete="off">
                    <div class="flex flex-row gap-1.5" id="rackLeftSlots"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col gap-4" style="min-height: 90vh;">
        <div class="grid grid-cols-2 gap-4 p-4" style="min-height: calc(100% - 73px);padding-top: 0px !important;">
            <!-- Left: System Control (3 cols = 50%) -->
            <div class="col-span-1 flex flex-col gap-4">
                <!-- System Control -->
                <div class="rounded-xl p-6 flex flex-col" style="background:#fff;border:1px solid #e5e7eb;">
                    <h2 class="text-xs font-semibold mb-2 flex items-center gap-2" style="color:#4b5563;">
                        <i class="bi-controller" data-lucide="sliders-horizontal" style="width:14px;height:14px;"></i> System Control
                    </h2>
                    <div class="flex flex-wrap gap-1.5 mb-2">
                        <div class="flex items-center gap-2">
                            <label for="job-input" class="text-xs font-semibold" style="color:#4b5563;white-space:nowrap;">Job : </label>
                            <input type="text" id="job-input" value="@ViewBag.QNo" class="flex-1 px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;" disabled>
                        </div>
                        <div class="flex items-center gap-2">
                            <label for="loader-input" class="text-xs font-semibold" style="color:#4b5563;white-space:nowrap;">Loader : </label>
                            <input type="text" id="loader-input" class="flex-1 px-2.5 py-1.5 rounded-lg text-xs border" style="border-color:#e5e7eb;color:#374151;background:#fff;">
                        </div>
                        <div class="flex items-center gap-2">
                            <label for="chkAutoRun" class="text-xs font-semibold" style="color:#4b5563;white-space:nowrap;">Auto : </label>
                            <input type="checkbox" id="chkAutoRun" style="width:14px;height:14px;cursor:pointer;">
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-1.5 mb-2">
                        <button id="start-btn" class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all" style="background:#10b981;color:#fff;"
                                onclick="systemStart()">
                            <i class="bi-play-fill" style="width:12px;height:12px;"></i> Start
                        </button>
                        <button id="cont-btn" class="hidden flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all" style="background:#f59e0b;color:#fff; "
                                onclick="systemCont()">
                            <i class="bi-pause-fill" style="width:12px;height:12px;"></i> Continuos
                        </button>
                        <button id="stop-btn" class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all" style="background:#e74c3c;color:#fff;"
                                onclick="systemStop()">
                            <i class="bi-stop-fill" style="width:12px;height:12px;"></i> Stop
                        </button>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mb-6">
                        <div class="rounded-lg p-3 text-center" style="background:#fef3c7;border:1px solid #fde68a;">
